---
import LandingPageLayout from '../layouts/LandingPageLayout.astro';

const title = "Best Free Macro Tracker App - Track Macros";
const description = "Free macro tracker for protein, carbs, and fat. Real-time progress bars, automatic or custom goals, AI food logging. No paywalls, no ads. Works offline.";
const keywords = "macro tracker, free macro tracker, best free macro tracker, macro tracking app, macro app, track macros, protein carbs fat tracker, macronutrient tracker";
---

<LandingPageLayout title={title} description={description} keywords={keywords}>

  <!-- Hero copy -->
  <div class="bg-gradient-to-br from-gray-50 via-emerald-50/30 to-gray-50 dark:from-gray-900 dark:via-gray-800 dark:to-gray-900">
    <div class="max-w-6xl mx-auto px-4 pt-6 md:pt-8 pb-10 text-center">
      <div class="inline-flex items-center gap-1.5 bg-emerald-50 dark:bg-emerald-900/30 border border-emerald-200 dark:border-emerald-700 text-emerald-700 dark:text-emerald-400 text-sm font-medium px-4 py-1.5 rounded-full mb-6">
        100% free · No account required
      </div>
      <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-6 text-gray-900 dark:text-gray-100">The Best <span class="bg-gradient-to-r from-emerald-500 to-teal-500 bg-clip-text text-transparent">Free Macro Tracker</span></h1>
      <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-300 mb-8 leading-relaxed max-w-3xl mx-auto">
        Track protein, carbs, and fat with real-time progress bars, automatic or custom goals, and AI food logging. <span class="font-semibold text-gray-800 dark:text-gray-200">No paywalls, no ads, no account required.</span>
      </p>
      <a
        href="/?from=landing-page"
        class="inline-flex items-center gap-2 bg-gradient-to-r from-emerald-500 to-teal-500 hover:from-emerald-600 hover:to-teal-600 text-white font-bold text-lg py-4 px-12 rounded-xl shadow-lg shadow-emerald-500/30 hover:shadow-xl hover:shadow-emerald-500/40 transition-all active:scale-95 focus:outline-none focus:ring-4 focus:ring-emerald-300"
      >
        Start Tracking Macros Now →
      </a>
    </div>
  </div>

  <!-- Hero image -->
  <div class="bg-gray-800 dark:bg-gray-950">
    <div class="max-w-6xl mx-auto px-4">
      <picture>
        <source srcset="/hero-screenshot.webp" type="image/webp" media="(min-width: 768px)" />
        <source srcset="/hero-mobile.webp" type="image/webp" media="(max-width: 767px)" />
        <img
          src="/hero-screenshot.webp"
          alt="Free Calorie Track macro tracker showing protein, carbs, and fat progress bars"
          width="5000"
          height="3000"
          class="w-full h-auto"
          loading="eager"
          style="image-rendering: high-quality; transform: translateZ(0); will-change: transform;"
        />
      </picture>
    </div>
  </div>

  <!-- Value Props -->
  <div class="bg-gray-50 dark:bg-gray-800">
    <div class="max-w-6xl mx-auto px-4 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700 shadow-sm">
          <h3 class="font-bold text-lg mb-2 bg-gradient-to-r from-emerald-500 to-teal-500 bg-clip-text text-transparent">Track all 3 macros — free.</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">Real-time protein, carb, and fat progress bars. Automatic or custom macro goals. Barcode scanning and AI logging — all included. No premium tier, no trial that expires.</p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700 shadow-sm">
          <h3 class="font-bold text-lg mb-2 bg-gradient-to-r from-emerald-500 to-teal-500 bg-clip-text text-transparent">No account. No cloud.</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">Your data lives on your device, not on a server. There's nothing to sign up for, no email required, and nothing to hand over.</p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700 shadow-sm">
          <h3 class="font-bold text-lg mb-2 bg-gradient-to-r from-emerald-500 to-teal-500 bg-clip-text text-transparent">Works everywhere, even offline.</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">Install to your home screen from any browser — iPhone, Android, desktop. Runs like a native app and works without internet.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Features Grid -->
  <div class="bg-white dark:bg-gray-900">
    <div class="max-w-6xl mx-auto px-4 py-12">
