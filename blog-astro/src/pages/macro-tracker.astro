      <p class="text-center text-sm text-gray-500 dark:text-gray-400 mb-8">Everything you want. No paywalls.</p>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">

        <!-- Macro progress bars -->
        <div class="bg-gray-50 dark:bg-gray-700 rounded-xl p-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-600 dark:text-emerald-400 mb-3"><line x1="18" x2="18" y1="20" y2="10"/><line x1="12" x2="12" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="14"/></svg>
          <h3 class="font-bold text-sm text-gray-800 dark:text-gray-100">Macro progress bars</h3>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1 leading-relaxed">Real-time protein, carb, and fat bars that update as you log. See your daily balance at a glance.</p>
        </div>

        <!-- Automatic macro goals -->
        <div class="bg-gray-50 dark:bg-gray-700 rounded-xl p-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-600 dark:text-emerald-400 mb-3"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
