      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-200 dark:border-gray-700">
          <h3 class="font-bold text-lg mb-2">High Protein</h3>
          <p class="text-2xl font-bold text-emerald-600 dark:text-emerald-400 mb-2">40/30/30</p>
          <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">40% Protein · 30% Carbs · 30% Fat</p>
          <p class="text-sm text-gray-600 dark:text-gray-400">Best for: Fat loss, muscle retention</p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-200 dark:border-gray-700">
          <h3 class="font-bold text-lg mb-2">Keto</h3>
          <p class="text-2xl font-bold text-emerald-600 dark:text-emerald-400 mb-2">30/5/65</p>
          <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">30% Protein · 5% Carbs · 65% Fat</p>
          <p class="text-sm text-gray-600 dark:text-gray-400">Best for: Ketogenic diet, very low carb</p>
