# USDA FoodData Central API Key
# Get your free API key at: https://fdc.nal.usda.gov/api-key-signup
#
# The app uses a dual-API approach:
# - Primary: USDA FoodData Central (380k+ US foods, very reliable)
# - Fallback: Open Food Facts (2.8M+ global foods, less reliable)
#
# DEMO_KEY works but has limited rate limits (~1000 total requests).
# Get your own free key for production use.
VITE_USDA_API_KEY=your_api_key_here
